# =============================================================================
# Umgebungsvariablen (lokal: .env.local | Vercel: Project Settings → Environment Variables)
# =============================================================================

# --- Für die App (Vercel + lokal) ---

# Supabase (Pflicht für Produktsuche/Filialen aus Supabase)
# Supabase Dashboard → Project Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# Admin-Bereich (/admin) – Passwort zum Anmelden
ADMIN_PASSWORD=your-admin-password

# Admin-Session: HMAC-Signatur-Secret für den Admin-Cookie (mind. 32 Zeichen)
# Generieren: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
ADMIN_SESSION_SECRET=your-random-64-char-hex-string

# F13 Foto-Produkterfassung: Claude Vision (API-Route /api/process-photo)
# Anthropic Dashboard → API Keys. In .env.local und in Vercel eintragen.
ANTHROPIC_API_KEY=your-anthropic-api-key

# Server-seitig (API process-photo, apply-thumbnail-overwrites): Schreibzugriff auf products/photo_uploads
# In .env.local und in Vercel eintragen, damit Foto-Verarbeitung funktioniert.
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Sentry Error Tracking (optional – App funktioniert auch ohne)
NEXT_PUBLIC_SENTRY_DSN=
SENTRY_AUTH_TOKEN=
SENTRY_ORG=
SENTRY_PROJECT=

# --- Nur für lokale Scripts (optional) ---
# SUPABASE_SERVICE_ROLE_KEY wird auch von import-stores-DE, import-stores-AT, import-test-products genutzt.
